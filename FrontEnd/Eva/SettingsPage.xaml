<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Eva.SettingsPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0D0D0D">

    <Grid>
        <Image
            Source="circles_pattern.svg"
            Aspect="AspectFill"
            Opacity="1"
            HorizontalOptions="Fill"
            VerticalOptions="Fill" />
        <BoxView Color="#0D0D0D" Opacity="0.55" HorizontalOptions="Fill" VerticalOptions="Fill" />

        <ScrollView>
            <VerticalStackLayout
                Padding="32,48,32,40"
                Spacing="0"
                HorizontalOptions="Fill">

                <Label
                    Text="← Volver"
                    FontSize="14"
                    TextColor="#888888"
                    Margin="0,0,0,8">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnVolverTapped" />
                    </Label.GestureRecognizers>
                </Label>

                <Label
                    Text="Configuración"
                    FontSize="22"
                    FontAttributes="Bold"
                    TextColor="#E5E5E5"
                    Margin="0,0,0,8" />
                <Label
                    Text="Tu cuenta, lugares guardados y preferencias de la app."
                    FontSize="13"
                    TextColor="#888888"
                    LineBreakMode="WordWrap"
                    Margin="0,0,0,24" />

                <Label Text="Tu cuenta"
                       FontSize="13"
                       TextColor="#888888"
                       Margin="0,0,0,8" />

                <Border Stroke="#2A2A2A"
                        StrokeThickness="1"
                        BackgroundColor="#1A1A1A"
                        Padding="16"
                        StrokeShape="RoundRectangle 12"
                        Margin="0,0,0,20">
                    <VerticalStackLayout Spacing="10">
                        <Label x:Name="lblNombreCompleto"
                               FontSize="17"
                               FontAttributes="Bold"
                               TextColor="#E5E5E5" />
                        <Label x:Name="lblCorreo"
                               FontSize="14"
                               TextColor="#A3A3A3" />
                        <Label x:Name="lblSesionId"
                               FontSize="11"
                               TextColor="#666666"
                               LineBreakMode="TailTruncation" />
                        <Button Text="Editar perfil"
                                Clicked="OnEditarPerfilClicked"
                                BackgroundColor="#2A2A2A"
                                TextColor="#E5E5E5"
                                FontSize="15"
                                CornerRadius="10"
                                HeightRequest="44"
                                BorderWidth="0"
                                Margin="0,10,0,0" />
                        <Button Text="Mi vehículo"
                                Clicked="OnVehiculoClicked"
                                BackgroundColor="#2A2A2A"
                                TextColor="#E5E5E5"
                                FontSize="15"
                                CornerRadius="10"
                                HeightRequest="44"
                                BorderWidth="0"
                                Margin="0,8,0,0" />
                    </VerticalStackLayout>
                </Border>

                <Label Text="Mapa y destinos"
                       FontSize="13"
                       TextColor="#888888"
                       Margin="0,0,0,8" />

                <Button Text="Mis lugares (casa, trabajo…)"
                        Clicked="OnLugaresClicked"
                        BackgroundColor="#2A2A2A"
                        TextColor="#E5E5E5"
                        FontSize="16"
                        CornerRadius="12"
                        HeightRequest="52"
                        BorderWidth="0"
                        Margin="0,0,0,14" />

                <Label Text="Legal"
                       FontSize="13"
                       TextColor="#888888"
                       Margin="0,4,0,8" />

                <Button Text="Términos y condiciones"
                        Clicked="OnTerminosClicked"
                        BackgroundColor="#2A2A2A"
                        TextColor="#E5E5E5"
                        FontSize="16"
                        CornerRadius="12"
                        HeightRequest="52"
                        BorderWidth="0"
                        Margin="0,0,0,10" />

                <Button Text="Reportar un problema"
                        Clicked="OnReporteClicked"
                        BackgroundColor="#2A2A2A"
                        TextColor="#E5E5E5"
                        FontSize="16"
                        CornerRadius="12"
                        HeightRequest="52"
                        BorderWidth="0"
                        Margin="0,0,0,20" />

                <Label Text="Sistema"
                       FontSize="13"
                       TextColor="#888888"
                       Margin="0,0,0,8" />

                <Label x:Name="lblVersion"
                       FontSize="13"
                       TextColor="#737373"
                       Margin="0,0,0,12" />

                <Label Text="La app usa datos y ubicación según lo descrito en términos. Requiere conexión a internet para mapas y API."
                       FontSize="12"
                       TextColor="#6B7280"
                       LineBreakMode="WordWrap"
                       Margin="0,0,0,20" />

                <Button Text="Cerrar sesión"
                        Clicked="OnCerrarSesionClicked"
                        BackgroundColor="#3F1D1D"
                        TextColor="#FCA5A5"
                        FontSize="16"
                        CornerRadius="12"
                        HeightRequest="52"
                        BorderWidth="0"
                        Margin="0,8,0,0" />
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
