<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Eva.MainPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0D0D0D">

    <Grid>
        
        <Image
            Source="circles_pattern.svg"
            Aspect="AspectFill"
            Opacity="1"
            HorizontalOptions="Fill"
            VerticalOptions="Fill" />
        <BoxView Color="#0D0D0D" Opacity="0.55" HorizontalOptions="Fill" VerticalOptions="Fill" />

        <ScrollView>
            <VerticalStackLayout
                Padding="32,56,32,40"
                Spacing="0"
                VerticalOptions="Center"
                HorizontalOptions="Fill">

                
                <Image
                    x:Name="imgLogo"
                    Source="eva_logo.png"
                    HeightRequest="72"
                    WidthRequest="72"
                    HorizontalOptions="Center"
                    Margin="0,0,0,24"
                    Aspect="AspectFit" />

                <Label
                    Text="Mapa, rutas, cargadores y modo viaje: se muestran después de iniciar sesión."
                    FontSize="13"
                    TextColor="#888888"
                    HorizontalTextAlignment="Center"
                    HorizontalOptions="Fill"
                    Margin="0,0,0,32"
                    LineBreakMode="WordWrap" />

                <VerticalStackLayout Spacing="20">

                    <Border
                        Stroke="#2A2A2A"
                        StrokeThickness="1"
                        BackgroundColor="#1A1A1A"
                        Padding="16,0"
                        HeightRequest="52"
                        StrokeShape="RoundRectangle 12">
                        <Entry
                            x:Name="txtEmail"
                            Placeholder="Correo"
                            PlaceholderColor="#666666"
                            TextColor="#E5E5E5"
                            FontSize="15"
                            Keyboard="Email"
                            VerticalOptions="Center"
                            BackgroundColor="Transparent" />
                    </Border>

                    <Border
                        Stroke="#2A2A2A"
                        StrokeThickness="1"
                        BackgroundColor="#1A1A1A"
                        Padding="16,0"
                        HeightRequest="52"
                        StrokeShape="RoundRectangle 12">
                        <Entry
                            x:Name="txtPassword"
                            Placeholder="Contraseña"
                            PlaceholderColor="#666666"
                            TextColor="#E5E5E5"
                            FontSize="15"
                            IsPassword="True"
                            VerticalOptions="Center"
                            BackgroundColor="Transparent" />
                    </Border>
                </VerticalStackLayout>

               
                <Grid Margin="0,32,0,0">
                    <Button
                        x:Name="btnIngresar"
                        Text="Ingresar"
                        Clicked="btnIngresar_Clicked"
                        BackgroundColor="#2A2A2A"
                        TextColor="#E5E5E5"
                        FontSize="16"
                        CornerRadius="12"
                        HeightRequest="52"
                        BorderWidth="0" />

                    <ActivityIndicator
                        x:Name="spinner"
                        IsRunning="False"
                        IsVisible="False"
                        Color="#E5E5E5"
                        HorizontalOptions="Center"
                        VerticalOptions="Center" />
                </Grid>

            
                <Grid Margin="0,28,0,0" ColumnDefinitions="*,*">
                    <Label
                        x:Name="lblRegistrarse"
                        Grid.Column="0"
                        Text="Registrarse"
                        FontSize="14"
                        TextColor="#888888"
                        HorizontalOptions="Start"
                        VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnRegistrarseTapped" />
                        </Label.GestureRecognizers>
                    </Label>
                    <Label
                        x:Name="lblTerminos"
                        Grid.Column="1"
                        Text="Términos y condiciones"
                        FontSize="14"
                        TextColor="#888888"
                        HorizontalOptions="End"
                        VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnTerminosTapped" />
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>

                <Label
                    Text="Activar cuenta con código"
                    FontSize="14"
                    TextColor="#666666"
                    HorizontalOptions="Center"
                    Margin="0,20,0,0">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnActivarCuentaTapped" />
                    </Label.GestureRecognizers>
                </Label>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
