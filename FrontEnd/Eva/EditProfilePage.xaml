<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Eva.EditProfilePage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0D0D0D">

    <Grid>
        <Image Source="circles_pattern.svg" Aspect="AspectFill" Opacity="1" HorizontalOptions="Fill" VerticalOptions="Fill" />
        <BoxView Color="#0D0D0D" Opacity="0.55" HorizontalOptions="Fill" VerticalOptions="Fill" />

        <ScrollView>
            <VerticalStackLayout Padding="32,48,32,40" Spacing="0" HorizontalOptions="Fill">
                <Label Text="← Volver" FontSize="14" TextColor="#888888" Margin="0,0,0,8">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnVolverTapped" />
                    </Label.GestureRecognizers>
                </Label>

                <Label Text="Editar perfil" FontSize="22" FontAttributes="Bold" TextColor="#E5E5E5" Margin="0,0,0,8" />
                <Label Text="Nombre, apellidos, dirección y tipo de cargador se guardan en tu cuenta."
                       FontSize="13" TextColor="#888888" LineBreakMode="WordWrap" Margin="0,0,0,20" />

                <Label Text="Correo (solo lectura)" FontSize="13" TextColor="#888888" Margin="0,0,0,6" />
                <Border Stroke="#2A2A2A" StrokeThickness="1" BackgroundColor="#141414" Padding="12,10" StrokeShape="RoundRectangle 10" Margin="0,0,0,14">
                    <Label x:Name="lblEmailReadonly" FontSize="15" TextColor="#737373" />
                </Border>

                <Label Text="Nombre" FontSize="13" TextColor="#888888" Margin="0,0,0,6" />
                <Entry x:Name="entryName" Placeholder="Nombre" TextColor="#E5E5E5" PlaceholderColor="#666666"
                       BackgroundColor="#1A1A1A" Margin="0,0,0,12" />

                <Label Text="Apellidos" FontSize="13" TextColor="#888888" Margin="0,0,0,6" />
                <Entry x:Name="entryLastName" Placeholder="Apellidos" TextColor="#E5E5E5" PlaceholderColor="#666666"
                       BackgroundColor="#1A1A1A" Margin="0,0,0,12" />

                <Label Text="Dirección" FontSize="13" TextColor="#888888" Margin="0,0,0,6" />
                <Entry x:Name="entryAdress" Placeholder="Dirección" TextColor="#E5E5E5" PlaceholderColor="#666666"
                       BackgroundColor="#1A1A1A" Margin="0,0,0,12" />

                <Label Text="Tipo de cargador" FontSize="13" TextColor="#888888" Margin="0,0,0,6" />
                <Entry x:Name="entryChargerType" Placeholder="Ej. Tipo 2, CCS, CHAdeMO…" TextColor="#E5E5E5" PlaceholderColor="#666666"
                       BackgroundColor="#1A1A1A" Margin="0,0,0,20" />

                <Button Text="Guardar cambios" Clicked="OnGuardarClicked" BackgroundColor="#2563EB" TextColor="White"
                        FontSize="16" CornerRadius="12" HeightRequest="52" BorderWidth="0" />
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
