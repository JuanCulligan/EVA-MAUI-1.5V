<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Eva.RegisterPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0D0D0D">

    <Grid>
        <Image
            Source="circles_pattern.svg"
            Aspect="AspectFill"
            Opacity="1"
            HorizontalOptions="Fill"
            VerticalOptions="Fill" />
        <BoxView Color="#0D0D0D" Opacity="0.55" HorizontalOptions="Fill" VerticalOptions="Fill" />

        <ScrollView>
            <VerticalStackLayout
                Padding="32,48,32,40"
                Spacing="0"
                VerticalOptions="Center"
                HorizontalOptions="Fill">

                <Label
                    Text="← Volver"
                    FontSize="14"
                    TextColor="#888888"
                    Margin="0,0,0,8">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnVolverTapped" />
                    </Label.GestureRecognizers>
                </Label>

                <Image
                    Source="eva_logo.png"
                    HeightRequest="64"
                    WidthRequest="64"
                    HorizontalOptions="Center"
                    Margin="0,0,0,28"
                    Aspect="AspectFit" />

                <Label
                    Text="Crear cuenta"
                    FontSize="22"
                    FontAttributes="Bold"
                    TextColor="#E5E5E5"
                    HorizontalOptions="Center"
                    Margin="0,0,0,8" />
                <Label
                    Text="Ubicación: elige país y ciudad; se guarda como dirección (País, Ciudad) hasta 50 caracteres. También necesitas contraseña segura y tipo de cargador."
                    FontSize="13"
                    TextColor="#888888"
                    HorizontalOptions="Center"
                    HorizontalTextAlignment="Center"
                    Margin="0,0,0,20"
                    LineBreakMode="WordWrap" />

                <VerticalStackLayout Spacing="14">

                    <Border
                        Stroke="#2A2A2A"
                        StrokeThickness="1"
                        BackgroundColor="#1A1A1A"
                        Padding="16,0"
                        HeightRequest="52"
                        StrokeShape="RoundRectangle 12">
                        <Entry
                            x:Name="txtNombre"
                            Placeholder="Nombre"
                            PlaceholderColor="#666666"
                            TextColor="#E5E5E5"
                            FontSize="15"
                            MaxLength="50"
                            VerticalOptions="Center"
                            BackgroundColor="Transparent" />
                    </Border>

                    <Border
                        Stroke="#2A2A2A"
                        StrokeThickness="1"
                        BackgroundColor="#1A1A1A"
                        Padding="16,0"
                        HeightRequest="52"
                        StrokeShape="RoundRectangle 12">
                        <Entry
                            x:Name="txtApellidos"
                            Placeholder="Apellidos"
                            PlaceholderColor="#666666"
                            TextColor="#E5E5E5"
                            FontSize="15"
                            MaxLength="50"
                            VerticalOptions="Center"
                            BackgroundColor="Transparent" />
                    </Border>

                    <Border
                        Stroke="#2A2A2A"
                        StrokeThickness="1"
                        BackgroundColor="#1A1A1A"
                        Padding="16,0"
                        HeightRequest="52"
                        StrokeShape="RoundRectangle 12">
                        <Entry
                            x:Name="txtEmail"
                            Placeholder="Correo electrónico"
                            PlaceholderColor="#666666"
                            TextColor="#E5E5E5"
                            FontSize="15"
                            Keyboard="Email"
                            MaxLength="50"
                            VerticalOptions="Center"
                            BackgroundColor="Transparent" />
                    </Border>

                    <Border
                        Stroke="#2A2A2A"
                        StrokeThickness="1"
                        BackgroundColor="#1A1A1A"
                        Padding="12,0"
                        HeightRequest="52"
                        StrokeShape="RoundRectangle 12">
                        <Picker
                            x:Name="pickerPais"
                            Title="País"
                            TextColor="#E5E5E5"
                            TitleColor="#666666"
                            FontSize="15"
                            VerticalOptions="Center"
                            BackgroundColor="Transparent" />
                    </Border>

                    <Border
                        Stroke="#2A2A2A"
                        StrokeThickness="1"
                        BackgroundColor="#1A1A1A"
                        Padding="12,0"
                        HeightRequest="52"
                        StrokeShape="RoundRectangle 12">
                        <Picker
                            x:Name="pickerCiudad"
                            Title="Ciudad"
                            TextColor="#E5E5E5"
                            TitleColor="#666666"
                            FontSize="15"
                            VerticalOptions="Center"
                            BackgroundColor="Transparent"
                            IsEnabled="False" />
                    </Border>

                    <Border
                        Stroke="#2A2A2A"
                        StrokeThickness="1"
                        BackgroundColor="#1A1A1A"
                        Padding="12,0"
                        HeightRequest="52"
                        StrokeShape="RoundRectangle 12">
                        <Picker
                            x:Name="pickerTipoCargador"
                            Title="Tipo de cargador"
                            TextColor="#E5E5E5"
                            TitleColor="#666666"
                            FontSize="15"
                            VerticalOptions="Center"
                            BackgroundColor="Transparent" />
                    </Border>

                    <Border
                        Stroke="#2A2A2A"
                        StrokeThickness="1"
                        BackgroundColor="#1A1A1A"
                        Padding="16,0"
                        HeightRequest="52"
                        StrokeShape="RoundRectangle 12">
                        <Entry
                            x:Name="txtPassword"
                            Placeholder="Contraseña"
                            PlaceholderColor="#666666"
                            TextColor="#E5E5E5"
                            FontSize="15"
                            IsPassword="True"
                            VerticalOptions="Center"
                            BackgroundColor="Transparent" />
                    </Border>

                    <Border
                        Stroke="#2A2A2A"
                        StrokeThickness="1"
                        BackgroundColor="#1A1A1A"
                        Padding="16,0"
                        HeightRequest="52"
                        StrokeShape="RoundRectangle 12">
                        <Entry
                            x:Name="txtPasswordConfirm"
                            Placeholder="Confirmar contraseña"
                            PlaceholderColor="#666666"
                            TextColor="#E5E5E5"
                            FontSize="15"
                            IsPassword="True"
                            VerticalOptions="Center"
                            BackgroundColor="Transparent" />
                    </Border>
                </VerticalStackLayout>

                <Label
                    Text="Contraseña: mínimo 8 caracteres, mayúscula, minúscula, número y un símbolo."
                    FontSize="12"
                    TextColor="#6B7280"
                    Margin="0,12,0,0"
                    LineBreakMode="WordWrap" />

                <Grid Margin="0,24,0,0">
                    <Button
                        x:Name="btnRegistrar"
                        Text="Registrarse"
                        Clicked="btnRegistrar_Clicked"
                        BackgroundColor="#2A2A2A"
                        TextColor="#E5E5E5"
                        FontSize="16"
                        CornerRadius="12"
                        HeightRequest="52"
                        BorderWidth="0" />

                    <ActivityIndicator
                        x:Name="spinnerRegistro"
                        IsRunning="False"
                        IsVisible="False"
                        Color="#E5E5E5"
                        HorizontalOptions="Center"
                        VerticalOptions="Center" />
                </Grid>

                <Label
                    Text="¿Ya tienes cuenta? Iniciar sesión"
                    FontSize="14"
                    TextColor="#888888"
                    HorizontalOptions="Center"
                    Margin="0,24,0,0">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnVolverTapped" />
                    </Label.GestureRecognizers>
                </Label>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
